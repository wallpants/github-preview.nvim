{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "ignorePatterns": [".github"],
  "printWidth": 100,
  "tabWidth": 3,
  "sortImports": {
    "newlinesBetween": false
  },
  "sortTailwindcss": {
    "stylesheet": "./app/web/static/app.css",
    "functions": ["cn"]
  },
  "overrides": [
    {
      "files": ["*.json", "*.md"],
      "options": {
        "tabWidth": 2
      }
    }
  ]
}
