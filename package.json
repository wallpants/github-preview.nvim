{
  "name": "github-preview.nvim",
  "version": "0.0.0",
  "private": true,
  "description": "Live preview of local github repos",
  "license": "MIT",
  "author": "wallpants",
  "repository": {
    "type": "git",
    "url": "git://github.com/wallpants/github-preview.nvim.git"
  },
  "type": "module",
  "scripts": {
    "commit": "cz",
    "format": "oxfmt .",
    "logs": "bunvim logs github-preview",
    "lint": "eslint . --ext ts --ext tsx --report-unused-disable-directives --max-warnings 0",
    "typecheck": "tsc -p ./app/tsconfig.json",
    "check": "bun run typecheck && bun run lint",
    "start": "bun run app/index.ts",
    "web:dev": "cd app/web && bun vite --open",
    "tailwind:compile": "tailwindcss -c ./app/web/tailwind.config.mjs -o ./app/web/static/tailwind.css"
  },
  "dependencies": {
    "bunvim": "1.1.13",
    "clsx": "^2.1.1",
    "globby": "^16.2.0",
    "isbinaryfile": "6.0.0",
    "mermaid": "^11.15.0",
    "opener": "^1.5.2",
    "pantsdown": "2.2.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "reconnecting-websocket": "^4.4.0",
    "tailwind-merge": "^3.6.0",
    "valibot": "^1.4.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@commitlint/config-conventional": "^21.0.2",
    "@commitlint/cz-commitlint": "^21.0.2",
    "@types/bun": "1.3.14",
    "@types/eslint": "^9.6.1",
    "@types/opener": "^1.4.3",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.60.0",
    "@typescript-eslint/parser": "^8.60.0",
    "@vitejs/plugin-react-swc": "^4.3.1",
    "autoprefixer": "^10.5.0",
    "commitizen": "^4.3.1",
    "commitlint": "^21.0.2",
    "eslint": "^10.4.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-tailwindcss": "^3.18.3",
    "inquirer": "^12.11.1",
    "oxfmt": "^0.52.0",
    "postcss": "^8.5.15",
    "semantic-release": "^25.0.3",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.14"
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ],
    "rules": {
      "body-max-line-length": [
        0
      ]
    }
  },
  "config": {
    "commitizen": {
      "path": "@commitlint/cz-commitlint"
    }
  },
  "release": {
    "branches": [
      "main"
    ]
  }
}
